# Copy this file to .env and fill in real local values.
# .env is gitignored — never commit it.

POSTGRES_USER=rentatodo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=rentatodo
POSTGRES_PORT=5432

# Full connection string used by SQLAlchemy (database.py).
# Host is "db" when running inside Docker Compose, "localhost" when
# running the API on your host machine against the containerized DB.
DATABASE_URL=postgresql+psycopg://rentatodo:changeme@localhost:5432/rentatodo

# JWT signing (app/config.py). Generate a real random value for production;
# any long string is fine for local dev.
JWT_SECRET=change-me-in-production-use-random-64-chars
JWT_EXPIRATION_HOURS=24

# Comma-separated list of origins allowed to call this API from a browser
# (CORS). Expo web's dev server runs on :8081 by default.
CORS_ORIGINS=http://localhost:8081

# AWS S3 — image uploads via pre-signed URLs.
# Credentials belong to the "rentatodo-api" IAM user (PutObject + DeleteObject only).
# Never commit real values — copy this file to .env and fill in locally.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=rentatodo-items-wa
AWS_S3_REGION=us-east-1
